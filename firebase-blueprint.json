{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information and balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Social media service order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "platform": { "type": "string" },
        "type": { "type": "string" },
        "link": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "link", "quantity", "totalPrice", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (deposit or order).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "order"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "paymentLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transactions collection."
    }
  }
}
